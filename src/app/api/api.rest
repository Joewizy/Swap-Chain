###############################################################################
# Paycrest — fiat off-ramp (PAYCREST_API_KEY; mainnet slugs; 501 if unset)
###############################################################################

### Paycrest order — NGN payout (OPay)
# Institution codes from GET /v1/institutions/ngn — e.g. OPAYNGPC (OPay),
# KUDANGPC (Kuda), PALMNGPC (PalmPay), MONINGPC (Moniepoint), GTBINGLA (GTBank).
# accountIdentifier is the account number (OPay = phone number without +234).
# Creating an order moves NO funds — payout only happens after you send the
# stablecoin to the returned receiveAddress before validUntil.
POST {{baseUrl}}/api/paycrest/order
Content-Type: application/json

{
  "amount": "0.5",
  "token": "USDC",
  "network": "base",
  "refundAddress": "{{wallet}}",
  "currency": "NGN",
  "recipient": { "institution": "OPAYNGPC", "accountIdentifier": "8170106043", "accountName": "Test User" },
  "reference": "swap-chain-rest-test"
}

### Paycrest order — off-ramp (explicit direction)
POST {{baseUrl}}/api/paycrest/order
Content-Type: application/json

{
  "direction": "offramp",
  "amount": "0.5",
  "token": "USDC",
  "network": "base",
  "refundAddress": "{{wallet}}",
  "currency": "NGN",
  "recipient": { "institution": "OPAYNGPC", "accountIdentifier": "8170106043"},
  "reference": "swap-chain-offramp-rest"
}

### Paycrest order — on-ramp NGN → USDC on Base
# Creating an order moves NO funds — deposit NGN to providerAccount before validUntil.
POST {{baseUrl}}/api/paycrest/order
Content-Type: application/json

{
  "direction": "onramp",
  "amount": "5000",
  "amountIn": "fiat",
  "fiatCurrency": "NGN",
  "token": "USDC",
  "network": "base",
  "recipientAddress": "{{wallet}}",
  "refundAccount": { "institution": "OPAYNGPC", "accountIdentifier": "8170106043"},
  "reference": "swap-chain-onramp-rest"
}

### Paycrest order — poll status (replace ORDER_ID)
GET {{baseUrl}}/api/paycrest/order/a6b7f345-6d04-4d4e-ba55-88ee4d9b7d81

