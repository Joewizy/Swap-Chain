###############################################################################
# Router — pick rail (body uses app ChainIds, e.g. base-sepolia)
###############################################################################

### Router — bridge USDC (→ cctp + inline fees)
POST {{baseUrl}}/api/router
Content-Type: application/json

{ "action": "bridge", "fromChain": "base-sepolia", "fromToken": "USDC", "amount": "10", "toChain": "arbitrum-sepolia", "toToken": "USDC" }

### Router — bridge USDC where CCTP unavailable (→ chainrails/relay)
POST {{baseUrl}}/api/router
Content-Type: application/json

{ "action": "bridge", "fromChain": "base-sepolia", "fromToken": "USDC", "amount": "1", "toChain": "sepolia", "toToken": "USDC" }

### Router — swap (→ relay)
POST {{baseUrl}}/api/router
Content-Type: application/json

{ "action": "swap", "fromChain": "base-sepolia", "fromToken": "ETH", "amount": "0.001", "toChain": "base-sepolia", "toToken": "USDC" }

### Router — off-ramp (→ paycrest)
POST {{baseUrl}}/api/router
Content-Type: application/json

{ "action": "offramp", "fromChain": "base", "fromToken": "USDC", "amount": "5", "fiatCurrency": "NGN" }

### Router — on-ramp NGN (→ paycrest)
POST {{baseUrl}}/api/router
Content-Type: application/json

{ "action": "onramp", "fromChain": "base", "fromToken": "USDC", "amount": "5000", "toChain": "base", "toToken": "USDC", "fiatCurrency": "NGN" }

### Router — on-ramp fallback (→ chainrails)
POST {{baseUrl}}/api/router
Content-Type: application/json

{ "action": "onramp", "fromChain": "base-sepolia", "fromToken": "USDC", "amount": "100", "fiatCurrency": "EUR" }

