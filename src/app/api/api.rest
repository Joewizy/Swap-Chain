@usdcArbitrumSepolia = 0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
@usdcBase = 0x833589fCD6EDb6E08f4c7C32D4f71b54bdA02913
@usdcArbitrum = 0xaf88d065e77c8cC2239327C5EDb3A432268e5831

