Content-Type: application/json
Authorization: Bearer {{$dotenv CHAINRAILS_API_KEY}}

{
  "sender": "{{wallet}}",
  "amount": "1000000",
  "tokenIn": "{{usdcBaseSepolia}}",
  "amountSymbol": "USDC",
  "source_chain": "BASE_TESTNET",
  "destination_chain": "ARBITRUM_TESTNET",
