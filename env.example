# ---------------------------------------------------------------------------
# Network universe — flips testnet ⇄ mainnet across every rail.
# See ARCHITECTURE.md §4.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_NETWORK=testnet


# ---------------------------------------------------------------------------
# Wallet (RainbowKit / WalletConnect)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_WALLET_CONNECT_ID=your_wallet_connect_project_id_here


# ---------------------------------------------------------------------------
# AI / intent parser
# ---------------------------------------------------------------------------
# Defaults to GitHub Models inference if OPENAI_BASE_URL is unset:
#   https://models.github.ai/inference
# Override with https://api.openai.com/v1 to use OpenAI directly.
OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=openai/gpt-4o-mini


# ---------------------------------------------------------------------------
# Phase 1 placeholders — uncomment as the rails come online.
# ---------------------------------------------------------------------------

# Chainrails (inbound + fiat on-ramp)
# CHAINRAILS_API_KEY=
# CHAINRAILS_BASE_URL=https://api.chainrails.io

# Paycrest (fiat off-ramp to bank / mobile money)
# Mainnet only — no sandbox. Get a key from https://app.paycrest.io
# PAYCREST_API_KEY=
# PAYCREST_WEBHOOK_SECRET=

# Circle CCTP (USDC ↔ USDC outbound)
# CIRCLE_API_KEY=

# Relay attribution (optional — lets Relay credit volume to our app)
# NEXT_PUBLIC_RELAY_APP_ID=


# ---------------------------------------------------------------------------
# Optional private RPCs
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_BASE_RPC_URL=
# NEXT_PUBLIC_STARKNET_RPC_URL=

# ARGENT_PRIVATE_KEY is intentionally absent — server-side custody was
# removed in Phase 0a. Starknet swaps will be re-added in Phase 2 with
# client-side signing via Argent / Braavos.
